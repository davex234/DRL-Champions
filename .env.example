# DRL Champions — variables de entorno
#
# Si NO defines estas variables, el juego funciona en MODO LOCAL (localStorage),
# exactamente como hasta ahora. Al definirlas, se activa el modo online
# (cuentas, sincronización en la nube, ranking y mercado entre jugadores).

# Supabase (Proyecto → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Panel de administración en producción (en desarrollo está siempre activo)
NEXT_PUBLIC_ADMIN=

# DRL Data Engine (opcional). Sin estas variables usa la fuente mock y solo
# registra incidencias en la app (sin Telegram).
# Endpoint JSON que mapea VLR.gg a la interfaz DataSource (proxy propio):
NEXT_PUBLIC_VLR_API=
# Webhook propio que reenvía a Telegram (NUNCA pongas aquí el token del bot):
NEXT_PUBLIC_TELEGRAM_WEBHOOK=
